{
  "name": "etherpad-cli-client",
  "description": "Node Client for Etherpad",
  "version": "4.0.2",
  "type": "module",
  "author": {
    "name": "John McLear",
    "email": "john@mclear.co.uk",
    "url": "http://mclear.co.uk"
  },
  "contributors": [
    {
      "name": "Dmitry Uvarov",
      "email": "uvarov.dl@gmail.com"
    }
